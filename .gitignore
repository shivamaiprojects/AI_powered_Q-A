# ---- Secrets ----
.env
.env.*
!.env.example

# ---- Virtual environments ----
.venv/
venv/
env/

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/

# ---- Data & artifacts (regenerable, and too large for git) ----
data/raw/*
data/processed/*
data/vectorstore/*
!data/**/.gitkeep

# ---- Model caches ----
.cache/
models/

# ---- Notebooks ----
.ipynb_checkpoints/

# ---- Reports: keep metrics, ignore heavy figures ----
reports/figures/*
!reports/figures/.gitkeep

# ---- IDE / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db